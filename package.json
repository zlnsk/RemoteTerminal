{
  "name": "remoteterminal",
  "version": "1.0.0",
  "private": true,
  "description": "Web SSH console (xterm.js + ssh2) with persistent per-target tmux sessions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');for(const m of ['shared-auth']){const d=p.join('node_modules',m);if(!fs.existsSync(d)){fs.mkdirSync('node_modules',{recursive:true});try{fs.symlinkSync(p.join('/opt/apps',m),d,'dir')}catch(e){}}}\""
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "ssh2": "^1.16.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
